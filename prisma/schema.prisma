// Prisma Schema - Sistem Tugas Akhir

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum Role {
  MAHASISWA
  DOSEN
  ADMIN
}

enum DosenSubRole {
  PEMBIMBING_1
  PEMBIMBING_2
  PENGUJI_1
  PENGUJI_2
}

enum StatusPendaftaran {
  MENUNGGU
  DITERIMA
  DITOLAK
  DISETUJUI_ADMIN
}

enum StatusJadwal {
  TERSEDIA
  TERISI
  DIBATALKAN
}

// ===================== MODELS =====================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MAHASISWA)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mahasiswa Mahasiswa?
  dosen     Dosen?
  sessions  Session[]
  accounts  Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Mahasiswa {
  id        String   @id @default(cuid())
  userId    String   @unique
  nim       String   @unique
  angkatan  String?
  prodi     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pendaftaranTugasAkhir PendaftaranTugasAkhir[]
  jadwalBimbingan       JadwalBimbingan[]
}

model Dosen {
  id        String   @id @default(cuid())
  userId    String   @unique
  nidn      String?  @unique
  prodi     String?
  maxSlot   Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bimbingan1 PendaftaranTugasAkhir[] @relation("Pembimbing1")
  bimbingan2 PendaftaranTugasAkhir[] @relation("Pembimbing2")
  pengujian1 PendaftaranTugasAkhir[] @relation("Penguji1")
  pengujian2 PendaftaranTugasAkhir[] @relation("Penguji2")

  jadwalBimbingan JadwalBimbingan[]
  jadwalSidang    JadwalSidang[]
}

model PendaftaranTugasAkhir {
  id               String            @id @default(cuid())
  mahasiswaId      String
  judulTA          String
  fileProposal     String
  fileProposalName String
  status           StatusPendaftaran @default(MENUNGGU)
  catatan          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  dosenPembimbing1Id String
  dosenPembimbing2Id String?
  dosenPenguji1Id    String?
  dosenPenguji2Id    String?

  mahasiswa        Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  dosenPembimbing1 Dosen     @relation("Pembimbing1", fields: [dosenPembimbing1Id], references: [id])
  dosenPembimbing2 Dosen?    @relation("Pembimbing2", fields: [dosenPembimbing2Id], references: [id])
  dosenPenguji1    Dosen?    @relation("Penguji1", fields: [dosenPenguji1Id], references: [id])
  dosenPenguji2    Dosen?    @relation("Penguji2", fields: [dosenPenguji2Id], references: [id])

  persetujuan     Persetujuan[]
  jadwalBimbingan JadwalBimbingan[]
  jadwalSidang    JadwalSidang[]
}

model Persetujuan {
  id            String            @id @default(cuid())
  pendaftaranId String
  dosenId       String
  subRole       DosenSubRole
  status        StatusPendaftaran
  catatan       String?
  createdAt     DateTime          @default(now())

  pendaftaran PendaftaranTugasAkhir @relation(fields: [pendaftaranId], references: [id], onDelete: Cascade)
}

// ===================== JADWAL =====================

/// Sesi bimbingan rutin yang dibuat dosen, bisa di-assign ke satu mahasiswa
model JadwalBimbingan {
  id            String       @id @default(cuid())
  dosenId       String
  tanggal       DateTime     @db.Date
  waktuMulai    String       // "HH:MM"
  waktuSelesai  String       // "HH:MM"
  keterangan    String?
  status        StatusJadwal @default(TERSEDIA)
  // Koneksi ke mahasiswa & pendaftaran (opsional — diisi saat sesi diassign)
  mahasiswaId   String?
  pendaftaranId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  dosen       Dosen                  @relation(fields: [dosenId], references: [id], onDelete: Cascade)
  mahasiswa   Mahasiswa?             @relation(fields: [mahasiswaId], references: [id])
  pendaftaran PendaftaranTugasAkhir? @relation(fields: [pendaftaranId], references: [id])

  @@index([dosenId, tanggal])
}

// ===================== KALENDER AKADEMIK =====================

/// Tanggal merah yang dikelola Admin — tampil di kalender semua dosen
model TanggalMerah {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  judul      String
  keterangan String?
  groupId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tanggal])
  @@index([groupId])
}
/// Window ketersediaan dosen untuk sidang; bisa di-link ke pendaftaran
model JadwalSidang {
  id                    String       @id @default(cuid())
  dosenId               String
  tanggal               DateTime     @db.Date
  waktuMulaiAvailable   String       // "HH:MM" — mulai dosen available
  waktuSelesaiAvailable String       // "HH:MM" — selesai dosen available
  keterangan            String?
  status                StatusJadwal @default(TERSEDIA)
  pendaftaranId         String?      // diisi saat slot ini digunakan untuk sidang mahasiswa
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  dosen       Dosen                  @relation(fields: [dosenId], references: [id], onDelete: Cascade)
  pendaftaran PendaftaranTugasAkhir? @relation(fields: [pendaftaranId], references: [id])

  @@index([dosenId, tanggal])
}
